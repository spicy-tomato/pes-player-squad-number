@page
@using PesPlayerSquadNumber.Models
@model SquadModel

@{
  ViewData["Title"] = "Squad";
}

<table class="table">
  <thead>
    <tr>
      <th scope="col">#</th>
      <th scope="col">Name</th>
      <th scope="col">Position</th>
      <th scope="col">Nation</th>
      <th scope="col">Club</th>
      <th scope="col">Current</th>
      <th scope="col">Recommended</th>
      <th scope="col">Age</th>
      <th scope="col">Action</th>
    </tr>
  </thead>

  <tbody id="squad-tbody">
    @for (int i = 0; i < Model.Result.Count; i++)
    {
      Player? player = Model.Result[i];

      @if (player != null)
      {
        <tr>
          <th scope="row">@(i + 1)</th>
          <td class="name">
            <img src="@player.ImageUrl" alt="@player.Name">
            <span>@player.Name</span>
          </td>
          <td class="position">@player.Position</td>
          <td class="nation">
            <img src="@player.Nation.ImageUrl" alt="@player.Nation.Name">
            <span>@player.Nation.Name</span>
          </td>
          <td class="club">
            @if (player.Club != null)
            {
              <img src="@player.Club.ImageUrl" alt="@player.Club.Name">
              <span>@player.Club.Name</span>
            }
          </td>
          <td class="current-number">@player.CurrentSquadNumber</td>
          <td class="current-number">@player.RecommendedSquadNumber</td>
          <td class="age">@player.Age</td>
          <td>
            <button type="button" class="player-popover btn btn-primary"
                    data-bs-toggle="popover"
                    data-squad-index="@i"
                    data-current-player-id="@player.Id">
              Re-assign
            </button>
          </td>
        </tr>
      }
      else
      {
        <tr>
          <th scope="row">@(i + 1)</th>
          <td>
            <button type="button" class="player-popover btn btn-primary"
                    data-bs-toggle="popover"
                    data-squad-index="@i"
                    data-current-player-id="">
              <i class="bi bi-plus"></i>
            </button>
          </td>
        </tr>
      }
    }
  </tbody>
</table>

@section Scripts {
  <script>
    let popovers = [];
    let allPlayers = [];

    function loadAllPlayers() {
      return $.ajax({
        url: 'Ppsn/GetAll/',
        type: 'GET',
        dataType: 'json',
        contentType: 'application/json'
      }).then(function (res) {
        allPlayers = res || [];
      });
    }

    function refreshSquad() {
      $.ajax({
        url: 'Ppsn/GetInSquad/',
        type: 'GET',
        dataType: 'json',
        contentType: 'application/json',
        success: function (players) {
          renderRows(players || []);
          initPopovers();
        }
      });
    }

    function renderRows(players) {
      const $tbody = $('#squad-tbody').empty();

      for (let i = 0; i < players.length; i++) {
        const p = players[i];
        const $tr = $(document.createElement('tr'));

        $tr.append(`<th scope="row">${i + 1}</th>`);

        if (p) {
          const clubHtml = p.club
            ? `<img src="${p.club.imageUrl}" alt="${p.club.name}"><span>${p.club.name}</span>`
            : '';
          const nationHtml = p.nation
            ? `<img src="${p.nation.imageUrl}" alt="${p.nation.name}"><span>${p.nation.name}</span>`
            : '';

          $tr.append(`
            <td class="name">
              <img src="${p.imageUrl}" alt="${p.name}">
              <span>${p.name}</span>
            </td>
            <td class="position">${p.position ?? ''}</td>
            <td class="nation">${nationHtml}</td>
            <td class="club">${clubHtml}</td>
            <td class="current-number">${p.currentSquadNumber ?? ''}</td>
            <td class="current-number">${p.recommendedSquadNumber ?? ''}</td>
            <td class="age">${p.age ?? ''}</td>
            <td>
              <button type="button" class="player-popover btn btn-primary"
                      data-bs-toggle="popover"
                      data-squad-index="${i}"
                      data-current-player-id="${p.id}">
                Re-assign
              </button>
            </td>
          `);
        } else {
          $tr.append(`
            <td>
              <button type="button" class="player-popover btn btn-primary"
                      data-bs-toggle="popover"
                      data-squad-index="${i}"
                      data-current-player-id="">
                <i class="bi bi-plus"></i>
              </button>
            </td>
          `);
        }

        $tbody.append($tr);
      }
    }

    function initPopovers() {
      popovers.forEach(p => p.dispose());
      const triggers = [].slice.call(document.querySelectorAll('.player-popover'));
      popovers = triggers.map(function (el) {
        const squadIndex = parseInt($(el).attr('data-squad-index'), 10);
        const currentPlayerId = $(el).attr('data-current-player-id');
        return new bootstrap.Popover(el, {
          content: buildPopupContent(squadIndex, currentPlayerId),
          html: true,
          container: 'body'
        });
      });
    }

    function buildPopupContent(squadIndex, currentPlayerId) {
      const $wrap = $(document.createElement('div'))
        .addClass('overflow-auto')
        .css('max-height', '400px');

      const candidates = allPlayers.filter(p => String(p.id) !== String(currentPlayerId));

      candidates.forEach((p, idx) => {
        const $row = $(document.createElement('div'))
          .addClass('d-flex align-items-center mt-1')
          .append($(document.createElement('div')).text(`${idx + 1}.`).addClass('me-1'))
          .append($(document.createElement('div')).addClass('me-1').text(p.name))
          .append(buildAssignBtn(p.id, squadIndex));
        $wrap.append($row);
      });

      return $wrap;
    }

    function buildAssignBtn(playerId, squadIndex) {
      const $btn = $($.parseHTML('<div type="button" class="btn btn-primary btn-sm">Assign</div>'));
      $btn.on('click', function () {
        assign(playerId, squadIndex);
      });
      return $btn;
    }

    function assign(playerId, squadIndex) {
      $.ajax({
        url: 'Ppsn/AssignToSquad/',
        type: 'POST',
        data: JSON.stringify({ playerId, squadIndex }),
        contentType: 'application/json',
        success: function () {
          refreshSquad();
        }
      });
    }

    $(document).ready(function () {
      loadAllPlayers().then(initPopovers);
    });
  </script>
}
